# ═══════════════════════════════════════════════════════════════
# NeuConX .gitignore
# SECURITY: This file prevents secrets and local data from
#           accidentally being committed to public GitHub repos.
# ═══════════════════════════════════════════════════════════════

# ── CRITICAL: Never commit these ─────────────────────────────────────────────
.env                        # API keys and SECRET_KEY live here
*.env                       # Any .env variant
.env.local
.env.production
secrets.json
credentials.json

# ── User Data (stays local, never cloud) ─────────────────────────────────────
data/conversations/         # Private chat history
data/profile.json           # Personal profile (name, goals, etc.)
memory/                     # ChromaDB vector store (Phase 5)

# ── Python Build Artifacts ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env.bak

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
NeuConX.log

# ── OS Artifacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
test_output/

# ── Packaging ─────────────────────────────────────────────────────────────────
*.spec               # PyInstaller spec (if using ClearSlate pattern)
dist_app/

# ── Flask Session Files ───────────────────────────────────────────────────────
flask_session/
instance/

# ── NOTE: Skills ARE committed (they are public templates) ───────────────────
# skills/*.md — committed intentionally as starter templates
