# MultiMind — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# SECURITY: Copy this file to .env and fill in your keys.
#           NEVER commit the .env file to git. It is in .gitignore.
#           NEVER share your .env file with anyone.
#           All keys are stored locally only — they never leave your machine
#           except when making direct API calls to the respective AI providers.
# ─────────────────────────────────────────────────────────────────────────────

# ── Session Security ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Required for persistent sessions across app restarts.
# If not set, a random key is generated each launch (sessions reset on restart).
SECRET_KEY=

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Free tier: 1,500 requests/day, 15 requests/minute
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── NVIDIA NIM ────────────────────────────────────────────────────────────────
# Free tier: 40 requests/minute (Llama 3.3 70B and more)
# Get key: https://build.nvidia.com → Sign in → Get API Key
NVIDIA_API_KEY=

# ── OpenRouter (DeepSeek + Mistral via free credits) ─────────────────────────
# Free tier: Free credits on signup, many free models available
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
